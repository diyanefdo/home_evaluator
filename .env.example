# Copy to .env and fill in to require login on a public link.
# docker compose reads .env automatically. Keep .env out of git (it's gitignored).

# Login toggle: on | off | (empty = auto)
#   auto -> login is ON when EVALUATOR_PASSWORD is set below, OFF otherwise
#   on   -> force login (a password is required)
#   off  -> no login, even if a password is set (handy for local/private use)
EVALUATOR_AUTH=off

EVALUATOR_USER=admin
EVALUATOR_PASSWORD=change-me-to-a-strong-password

# Live market data: overlay the current 5yr mortgage rate from the Bank of
# Canada (falls back to baked-in regional rates if offline). on (default) | off
EVALUATOR_LIVE_DATA=on
