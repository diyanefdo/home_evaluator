# Copy to .env and fill in to require login on a public link.
# docker compose reads .env automatically. Keep .env out of git (it's gitignored).

# Login toggle: on | off | (empty = auto)
#   auto -> login is ON when EVALUATOR_PASSWORD is set below, OFF otherwise
#   on   -> force login (a password is required)
#   off  -> no login, even if a password is set (handy for local/private use)
EVALUATOR_AUTH=off

EVALUATOR_USER=admin
EVALUATOR_PASSWORD=change-me-to-a-strong-password

# Live market data: overlay the current 5yr mortgage rate from the Bank of
# Canada (falls back to baked-in regional rates if offline). on (default) | off
EVALUATOR_LIVE_DATA=on

# --- Phase 2: accounts (Postgres + Google OAuth) -----------------------------
# Password for the bundled Postgres `db` container (compose builds EVALUATOR_DB
# from it automatically). Change it for any real deployment.
POSTGRES_PASSWORD=evalpass

# Accounts stay OFF until BOTH Google credentials are set. Create an OAuth 2.0
# "Web application" client at https://console.cloud.google.com/apis/credentials
# with an authorized redirect URI of  <your-base-url>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Signs the session cookie — set a long random value in production
# (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
EVALUATOR_SECRET_KEY=

# Comma-separated emails allowed to view the /admin analytics dashboard.
EVALUATOR_ADMIN_EMAILS=

# Only needed if the auto-detected callback URL is wrong (e.g. behind a proxy or
# Tailscale Funnel). Must exactly match the Google client's redirect URI.
# EVALUATOR_OAUTH_REDIRECT=https://your-host/auth/google/callback

# Override the whole DB URL if you don't use the bundled `db` container.
# EVALUATOR_DB=postgresql+psycopg://user:pass@host:5432/dbname
